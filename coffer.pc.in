prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: coffer
Description: Standalone virtual terminal engine (UAX-aware grapheme clustering, scrollback, reflow)
URL: https://github.com/thomas-christensen/coffer
Version: @COFFER_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lcoffer @THORVG_LIBS@ -lm
